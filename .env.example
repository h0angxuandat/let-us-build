# ── let-us-build environment (copy to .env; NEVER commit .env) ───────────────

# Core API
LUB_HOST=127.0.0.1
LUB_PORT=8300

# Web (SolidStart dev server)
LUB_WEB_PORT=8301

# Database (Postgres + pgvector — see docker-compose.yml)
LUB_DATABASE_URL=postgresql+asyncpg://lub:lub@127.0.0.1:5432/letusbuild

# LLM providers (per-agent provider/model config; day-one: Anthropic + OpenAI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Defaults used when an agent has no explicit override
LUB_DEFAULT_PROVIDER=anthropic
LUB_DEFAULT_MODEL=claude-opus-4-8
